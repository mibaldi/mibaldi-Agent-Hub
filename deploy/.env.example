# ==========================================================================
# Mibaldi Agent Hub — variables del STACK de Portainer (deploy desde GHCR).
# Copia estos valores en el editor de variables del stack (o en un .env).
# NUNCA subas el .env real al repo.
# ==========================================================================

# --- Imagen publicada en GHCR ---
# Tag a desplegar. Usa una versión fija (1.0.0) en prod; "dev"/"latest" si quieres rolling.
IMAGE_TAG=1.0.0

# --- Base de datos PostgreSQL (servicio "postgres", volumen "pgdata") ---
# MANTÉN estos valores iguales a los del despliegue actual para reutilizar la BD.
POSTGRES_USER=mah
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=mibaldi_agent_hub

# --- API ---
# Host del stack en el host físico y puerto dedicado.
# BIND_ADDR = IP de Tailscale -> accesible SOLO desde la tailnet. 0.0.0.0 = expuesto.
BIND_ADDR=100.83.238.95
HOST_PORT=48080

# --- Autenticación (usuario admin único inicial) ---
ADMIN_USERNAME=admin
# Texto plano SOLO para arranque inicial; en prod usa ADMIN_PASSWORD_HASH (bcrypt).
ADMIN_PASSWORD=changeme_admin_password
ADMIN_PASSWORD_HASH=

# Secreto para firmar JWT. Genera con: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_long_random_secret
JWT_EXPIRES_IN=12h

# Clave AES-256 (64 hex chars = 32 bytes) para cifrar passwords/claves SSH en BD.
# Genera con: openssl rand -hex 32
APP_ENCRYPTION_KEY=changeme_64_hex_chars_0000000000000000000000000000000000000000

    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "ssh2": "^1.16.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"

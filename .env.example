# ==========================================================================
# Mibaldi Agent Hub - variables de entorno
# Copia este fichero a .env y ajusta los valores. NUNCA subas .env al repo.
# ==========================================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=mah
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=mibaldi_agent_hub
# La API usa DATABASE_URL. En docker-compose apunta al servicio "postgres".
DATABASE_URL=postgresql://mah:changeme_db_password@postgres:5432/mibaldi_agent_hub?schema=public

# --- API ---
API_PORT=8080
# Host de escucha. 0.0.0.0 dentro de Docker; usa 127.0.0.1 si lo expones tras Tailscale.
API_HOST=0.0.0.0

# --- Autenticacion (usuario admin unico inicial) ---
ADMIN_USERNAME=admin
# Contrasena en texto plano SOLO para arranque inicial. Se hashea en memoria.
# En produccion usa ADMIN_PASSWORD_HASH (bcrypt) y deja ADMIN_PASSWORD vacio.
ADMIN_PASSWORD=changeme_admin_password
ADMIN_PASSWORD_HASH=

# Secreto para firmar los JWT. Genera uno con: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_long_random_secret
JWT_EXPIRES_IN=12h

# Clave AES-256 (64 hex chars = 32 bytes) para cifrar passwords/claves SSH en BD.
# Genera con: openssl rand -hex 32
APP_ENCRYPTION_KEY=changeme_64_hex_chars_0000000000000000000000000000000000000000

# --- Frontend ---
# En desarrollo el web (Vite) corre en 5173 y proxya /api hacia la API.
# En produccion la API sirve los estaticos del web compilado.
WEB_ORIGIN=http://localhost:5173
